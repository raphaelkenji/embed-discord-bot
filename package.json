{
  "name": "discord-embed-bot",
  "version": "1.0.0",
  "description": "Discord bot for URL replacement and embed generation",
  "main": "dist/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev:watch": "ts-node --watch src/index.ts",
    "db:init": "docker-compose exec postgres psql -U discord_user -d discord_bot -f /docker-entrypoint-initdb.d/01_schema.sql",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "discord-embed-bot"
  },
  "author": "raphaelkenji",
  "license": "ISC",
  "dependencies": {
    "discord.js": "^14.21.0",
    "dotenv": "^17.2.0",
    "glob": "^11.0.3",
    "node-cache": "^5.1.2",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "@types/pg": "^8.15.4",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "jest": "^30.0.4",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
