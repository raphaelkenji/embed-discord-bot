{
  "name": "discord-embed-bot",
  "version": "1.0.0",
  "description": "Discord bot for URL replacement and embed generation",
  "main": "dist/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev:watch": "ts-node --watch src/index.ts",
    "db:init": "docker-compose exec postgres psql -U discord_user -d discord_bot -f /docker-entrypoint-initdb.d/01_schema.sql",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "clean": "rimraf dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "discord-embed-bot"
  },
  "author": "raphaelkenji",
  "license": "ISC",
  "dependencies": {
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.0",
    "glob": "^13.0.6",
    "node-cache": "^5.1.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
